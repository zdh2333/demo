# e-Stat API Application ID
# 从 https://www.e-stat.go.jp 注册后在「マイページ」→「API機能」获取
ESTAT_APP_ID=your_application_id_here

# API 代理服务器端口（默认 3001）
API_PORT=3001

# ============================================================
# Supabase 后端配置（论坛 + 用户认证）
# 1. 在 https://supabase.com 免费创建项目
# 2. 进入项目 Settings → API 获取以下两个值
# 3. 在 SQL Editor 中运行 supabase/migration.sql 创建表结构
# ============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
